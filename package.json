{
  "name": "relux-astro",
  "version": "1.0.0",
  "description": "A modern and elegant web template for luxury hotels, resorts, and boutique stays. Showcase rooms, amenities, and experiences with stunning visuals, smooth booking, and a five-star design built to impress and convert visitors effortlessly.",
  "author": "Themefisher",
  "license": "UNLICENSED",
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"astro dev\"",
    "build": "node scripts/themeGenerator.js && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier -w ./src"
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/mdx": "4.3.13",
    "@astrojs/react": "4.4.2",
    "@astrojs/sitemap": "3.7.0",
    "@digi4care/astro-google-tagmanager": "^1.6.0",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "aos": "^2.3.4",
    "astro": "5.17.2",
    "astro-auto-import": "^0.5.1",
    "astro-font": "^1.1.0",
    "astro-swiper": "^2.1.0",
    "date-fns": "^4.1.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "lenis": "^1.3.17",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
