---
import Star from "@/components/shapes/Star";

interface Props {
  rating: number;
  max?: number;
  size?: string;
  color?: string;
  class?: string;
}

const {
  rating,
  max = 5,
  size = "w-4 h-4",
  color = "var(--color-primary)",
  class: className,
} = Astro.props;

const fullStars = Math.floor(rating);
const hasHalf = rating - fullStars >= 0.5;
const emptyStars = max - fullStars - (hasHalf ? 1 : 0);
---

<div class={className}>
  {
    Array.from({ length: fullStars }).map(() => (
      <Star className={`${size} inline mr-1 -mt-1`} color={color} client:load />
    ))
  }
  {
    hasHalf && (
      <span class="inline-block w-2 overflow-hidden align-middle mr-1 -mt-1">
        <Star className={size} color={color} client:load />
      </span>
    )
  }
  {
    Array.from({ length: emptyStars }).map(() => (
      <Star
        className={`${size} inline mr-1 -mt-1 opacity-30`}
        color={color}
        client:load
      />
    ))
  }
</div>
