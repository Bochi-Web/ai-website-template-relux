---
import Button from "@/components/Button.astro";
import ImageMod from "@/components/ImageMod.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { Swiper, SwiperSlide, SwiperWrapper } from "astro-swiper";
import type { SwiperOptions } from "swiper/types";

const swiperOptions: SwiperOptions = {
  spaceBetween: 24,
  loop: false,
  centeredSlides: false,
  slidesPerView: "auto",
  navigation: {
    nextEl: ".room-swiper-button-next",
    prevEl: ".room-swiper-button-prev",
  },
  breakpoints: {
    768: {
      slidesPerView: 1,
    },
    992: {
      slidesPerView: 2,
    },
    1324: {
      slidesPerView: 3,
    },
  },
};

const pageIndex = await getListPage("homepage", "-index");
if (!pageIndex.data.room_slider.enable) return null;

const rooms = await getSinglePage("roomSinglePage");
---

<section class="section bg-light">
  <div class="container">
    <h2
      data-aos="fade-up-sm"
      data-aos-delay="200"
      class="text-center mb-22 xl:mb-12 xl:w-[20%] mx-auto"
      set:html={markdownify("Prestige Residences")}
    />

    <div class="relative">
      <!-- Custom arrow buttons -->
      <div class="absolute right-6 -top-16 z-10 flex items-center gap-2.5">
        <button
          type="button"
          class="room-swiper-button-prev bg-primary hover:text-body duration-500 ease-in-out cursor-pointer w-fit p-4 rounded-full border border-border transition-transform active:scale-95"
          data-aos="fade-right-sm"
          data-aos-delay="150"
        >
          <svg
            class="w-5"
            width="14"
            height="24"
            viewBox="0 0 14 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12.8281 0C12.8281 7.85455 4.94241 11.2727 0.999554 12C4.94241 12.7273 12.8281 16.1455 12.8281 24"
              stroke="var(--color-secondary)"
              stroke-width="2"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <button
          type="button"
          class="room-swiper-button-next bg-primary hover:text-body duration-500 ease-in-out cursor-pointer w-fit p-4 rounded-full border border-border transition-transform! active:scale-95"
          data-aos="fade-left-sm"
          data-aos-delay="150"
        >
          <svg
            class="w-5"
            width="14"
            height="24"
            viewBox="0 0 14 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M1 24C1 16.1455 8.88571 12.7273 12.8286 12C8.88571 11.2727 1 7.85455 1 0"
              stroke="var(--color-secondary)"
              stroke-width="2"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>

      <Swiper
        data-aos="fade-up-sm"
        data-aos-delay="250"
        options={swiperOptions}
        class="room-slider border border-primary"
      >
        <SwiperWrapper class={"p-6"}>
          {
            rooms?.map((room, index) => (
              <SwiperSlide class={"relative group"}>
                {room.data.image && (
                  <ImageMod
                    src={room.data.image}
                    alt={`slider image ${index + 1}`}
                    class="w-full h-[400px] lg:h-[800px] object-cover"
                    width={1500}
                    height={800}
                  />
                )}
                <div class="absolute inset-0 p-10 opacity-0 blur-xl group-hover:opacity-100 group-hover:blur-none transition-all duration-500 ease-in-out">
                  <div class="relative h-full w-full border border-primary">
                    <div class="absolute bg-body bottom-0 left-0 right-0 p-6 flex items-center justify-between gap-4">
                      <h4 class="h6" set:html={markdownify(room.data.title)} />
                      <Button
                        data={{
                          enable: true,
                          label: "Book now",
                          link: `/rooms/${room.id}`,
                        }}
                      />
                    </div>
                  </div>
                </div>
              </SwiperSlide>
            ))
          }
        </SwiperWrapper>
      </Swiper>
    </div>
  </div>
</section>
