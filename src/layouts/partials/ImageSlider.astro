---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import {
  Swiper,
  SwiperButtonNext,
  SwiperButtonPrev,
  SwiperSlide,
  SwiperWrapper,
} from "astro-swiper";
import type { SwiperOptions } from "swiper/types";

const swiperOptions: SwiperOptions = {
  spaceBetween: 24,
  loop: true,
  centeredSlides: true,
  slidesPerView: "auto",
  autoplay: {
    delay: 2500,
    disableOnInteraction: false,
  },
  navigation: {
    nextEl: ".swiper-button-next",
    prevEl: ".swiper-button-prev",
  },
  breakpoints: {
    768: {
      slidesPerView: 1,
    },
    992: {
      slidesPerView: "auto",
    },
    1024: {
      slidesPerView: "auto",
    },
  },
};

const pageIndex = await getListPage("homepage", "-index");
if (!pageIndex.data.image_slider.enable) return null;

const { images, features } = pageIndex.data.image_slider;
---

<section class="bg-light">
  <Swiper options={swiperOptions} class="image-slider">
    <SwiperWrapper class={"mb-12"}>
      {
        images?.map((image, index) => (
          <SwiperSlide>
            <ImageMod
              src={image.image}
              alt={image.alt_text || `Image ${index + 1}`}
              class="w-full h-[400px] lg:h-[800px] object-cover"
              width={1500}
              height={800}
            />
          </SwiperSlide>
        ))
      }
    </SwiperWrapper>
    <SwiperButtonNext
      data-aos="fade-right-sm"
      data-aos-delay="250"
      class="swiper-button-next"
    />
    <SwiperButtonPrev
      data-aos="fade-left-sm"
      data-aos-delay="250"
      class="swiper-button-prev"
    />
  </Swiper>

  <div class="container md:-mt-34 relative z-10">
    <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5">
      {
        features?.map((f, i) => (
          <div
            data-aos="fade-up-sm"
            data-aos-delay={`${i * 100}`}
            class="bg-body p-7"
          >
            <DynamicIcon icon={f.icon} className="w-12 h-12 text-primary" />
            <h3 class="h5 mt-10" set:html={markdownify(f.label)} />
          </div>
        ))
      }
    </div>
  </div>
</section>
