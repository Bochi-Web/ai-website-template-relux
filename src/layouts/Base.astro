---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

// font families - extract font names for Font component (filter out type keys)
const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  isNotFound?: boolean;
}
// destructure frontmatter
const {
  title,
  meta_title,
  description,
  image,
  noindex,
  canonical,
  isNotFound,
} = Astro.props;
---


<!doctype html>
<html lang="en">
  <head>
    <!-- google tag manager -->
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanager id={config.google_tag_manager.gtm_id} />
      )
    }
    <!-- favicon -->
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="Relux Astro" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css - Astro 6 built-in Font API -->
    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload />;
      })
    }

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>
      {plainify(meta_title ? meta_title : title ? title : config.site.title)}
    </title>

    <!-- canonical url -->
    {canonical && <link rel="canonical" href={canonical} item-prop="url" />}

    <!-- noindex robots -->
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- meta-description -->
    <meta
      name="description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />

    <ClientRouter />

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- og-title -->
    <meta
      property="og:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title,
      )}
    />

    <!-- og-description -->
    <meta
      property="og:description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`${config.site.base_url}/${Astro.url.pathname.replace("/", "")}`}
    />

    <!-- twitter-title -->
    <meta
      name="twitter:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title,
      )}
    />

    <!-- twitter-description -->
    <meta
      name="twitter:description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />

    <!-- og-image -->
    <meta
      property="og:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />

    <!-- twitter-image -->
    <meta
      name="twitter:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    {/* google tag manager noscript */}
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={config.google_tag_manager.gtm_id} />
      )
    }

    <TwSizeIndicator />
    <Header isNotFound={isNotFound} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      import AOS from "aos";
      import "aos/dist/aos.css";
      import Lenis from "lenis";

      declare global {
        interface Window {
          __reluxBaseInit?: boolean;
        }
      }

      // Prevent duplicate listeners/instances (can happen with HMR or reinjected scripts)
      if (!window.__reluxBaseInit) {
        window.__reluxBaseInit = true;

        // Always start at the top (disable native scroll restoration)
        if ("scrollRestoration" in history) {
          history.scrollRestoration = "manual";
        }

        let lenis: Lenis | null = null;
        let rafId: number | null = null;
        const onLenisScroll = () => {
          AOS.refresh();
        };

        function scrollToTop() {
          if (lenis) {
            lenis.scrollTo(0, { immediate: true });
            return;
          }
          window.scrollTo(0, 0);
        }

        function initAOS() {
          AOS.init({
            duration: 600,
            offset: 100,
            once: true,
          });

          // Ensure AOS recalculates after layout settles
          requestAnimationFrame(() => AOS.refreshHard());
        }

        function destroyLenis() {
          if (rafId !== null) cancelAnimationFrame(rafId);
          rafId = null;

          if (lenis) {
            lenis.off("scroll", onLenisScroll);
            lenis.destroy();
            lenis = null;
          }
        }

        function initLenis() {
          destroyLenis();

          lenis = new Lenis({
            autoRaf: false,
          });

          lenis.on("scroll", onLenisScroll);

          const raf = (time: number) => {
            if (!lenis) return;
            lenis.raf(time);
            rafId = requestAnimationFrame(raf);
          };

          rafId = requestAnimationFrame(raf);
        }

        document.addEventListener("astro:page-load", () => {
          scrollToTop();
          initAOS();
          initLenis();
          // Ensure Lenis (once initialized) also snaps to top
          scrollToTop();
        });

        // Scroll to top on route change
        document.addEventListener("astro:after-swap", () => {
          scrollToTop();
          initAOS();
        });

        // Scroll to top on full page reloads too
        window.addEventListener(
          "load",
          () => {
            scrollToTop();
          },
          { once: true },
        );

        // Handle bfcache restores
        window.addEventListener("pageshow", (event) => {
          if (event.persisted) scrollToTop();
        });

        // Cleanup before Astro swaps DOM
        document.addEventListener("astro:before-preparation", () => {
          destroyLenis();
        });

        // Keep AOS positions accurate if viewport changes
        window.addEventListener(
          "resize",
          () => {
            AOS.refresh();
          },
          { passive: true },
        );
      }
    </script>
  </body>
</html>
