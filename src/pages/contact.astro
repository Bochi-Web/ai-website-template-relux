---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import GallerySlider from "@/partials/GallerySlider.astro";
import NewsletterSocial from "@/partials/NewsletterSocial.astro";
import PageHeader from "@/partials/PageHeader.astro";

const pageIndex = await getListPage("contact", "-index");
if (pageIndex.data.draft) return Astro.redirect("/404");

const { title, image, subtitle, contact_section } = pageIndex.data;
---

<Base {...pageIndex.data}>
  <PageHeader title={title} subtitle={subtitle} backgroundImage={image} />

  <section class="section bg-light">
    <div class="container">
      <h2
        data-aos="fade-up-sm"
        data-aos-delay="200"
        class="h1 text-center text-balance"
        set:html={markdownify(contact_section.title)}
      />

      <div
        class="flex flex-col-reverse lg:flex-row border-t border-b border-primary mt-10"
      >
        <div
          data-aos="fade-right-sm"
          data-aos-delay="200"
          class="lg:w-[40%] py-12 flex flex-col"
        >
          <h2 class="mb-4">Book a stay</h2>

          <div class="flex flex-col gap-3 flex-1">
            <a
              href={`mailto:${config.contact_info.email}`}
              class="flex items-center gap-2 h6 hover:text-text-dark transition-colors duration-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 1.99 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5L4 8V6l8 5 8-5v2z"
                ></path>
              </svg>
              {config.contact_info.email}
            </a>

            <a
              href={`tel:${config.contact_info.phone}`}
              class="flex items-center gap-2 h6 hover:text-text-dark transition-colors duration-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21c1.2.48 2.5.74 3.82.74a1 1 0 011 1V20a1 1 0 01-1 1C10.29 21 3 13.71 3 5a1 1 0 011-1h3a1 1 0 011 1c0 1.32.26 2.62.74 3.82a1 1 0 01-.21 1.11l-2.2 2.2z"
                ></path>
              </svg>
              {config.contact_info.phone}
            </a>

            <a
              href={`https://www.google.com/maps/search/${encodeURIComponent(
                config.contact_info.address,
              )}`}
              class="mt-auto flex items-center gap-2 h6 hover:text-text-dark transition-colors duration-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"
                ></path>
              </svg>
              {config.contact_info.address}
            </a>
          </div>
        </div>

        <div
          data-aos="fade-left-sm"
          data-aos-delay="200"
          class="bg-body lg:w-[60%] p-12 lg:border-l border-primary"
        >
          <h3 class="mb-4">Send a message</h3>
          <form action={config.params.contact_form_action}>
            <div class="flex flex-col gap-4">
              <div class="flex max-sm:flex-col gap-4">
                <input
                  type="text"
                  placeholder="First Name"
                  class="w-full form-input bg-transparent"
                  required
                />
                <input
                  type="text"
                  placeholder="Last Name"
                  class="w-full form-input bg-transparent"
                  required
                />
              </div>
              <div class="flex max-sm:flex-col gap-4">
                <input
                  type="email"
                  placeholder="Email"
                  class="w-full form-input bg-transparent"
                  required
                />

                <input
                  type="tel"
                  placeholder="Phone Number"
                  class="w-full form-input bg-transparent"
                  required
                />
              </div>
              <textarea
                placeholder="Write your message here..."
                class="form-input resize-none h-32 bg-transparent"
                required></textarea>
              <button type="submit" class="btn btn-primary w-full py-4">
                Send Message
              </button>
            </div>
          </form>
        </div>
      </div>

      <NewsletterSocial />
      <GallerySlider />
    </div>
  </section>
</Base>
