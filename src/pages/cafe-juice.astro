---
import ImageMod from "@/components/ImageMod.astro";
import SeparatorHalf from "@/components/shapes/SeparatorHalf";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToAction from "@/partials/CallToAction.astro";
import GallerySlider from "@/partials/GallerySlider.astro";
import NewsletterSocial from "@/partials/NewsletterSocial.astro";
import PageHeader from "@/partials/PageHeader.astro";

const pageIndex = await getListPage("cafeJuice", "-index");
if (pageIndex.data.draft) return Astro.redirect("/404");

const { title, image, subtitle, menu_section, gallery_section } =
  pageIndex.data;
---

<Base {...pageIndex.data}>
  <PageHeader title={title} subtitle={subtitle} backgroundImage={image} />

  {
    gallery_section.enable && (
      <section class="section">
        <div class="container">
          <SeparatorHalf
            className="-rotate-180 h-2.5 lg:h-6 w-fit"
            client:load
          />

          <div class="flex max-lg:flex-col gap-4 justify-between items-center my-10">
            <h2
              data-aos="fade-up-sm"
              data-aos-delay="150"
              class="flex-2/3 text-balance"
              set:html={markdownify(gallery_section.title)}
            />
            <div class="flex-1/3">
              <p
                data-aos="fade-up-sm"
                data-aos-delay="150"
                class="h6 text-text uppercase"
                set:html={markdownify(gallery_section.description.title)}
              />

              {gallery_section.description.list_texts.length > 0 && (
                <ul class="list-disc list-inside text-text-dark mt-4">
                  {gallery_section.description.list_texts?.map((item, i) => (
                    <li
                      data-aos="fade-up-sm"
                      data-aos-delay={i * 150}
                      set:html={markdownify(item)}
                    />
                  ))}
                </ul>
              )}
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {gallery_section.images.map((image, index) => (
              <figure
                data-aos="fade-up-sm"
                data-aos-delay="200"
                class={`${(index + 1) % 3 === 0 ? "md:col-span-2" : ""}`}
              >
                <ImageMod
                  src={image}
                  width={1688}
                  height={900}
                  alt={"Image of - " + gallery_section.title}
                  format="webp"
                  class="w-full h-auto object-cover"
                />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    menu_section.enable && (
      <section class="section pt-0">
        <div
          class="container relative bg-cover bg-center bg-no-repeat p-15"
          style={`background-image: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url('${menu_section.image}');`}
        >
          <div
            data-aos="zoom-in-sm"
            data-aos-delay="200"
            class="relative z-10 bg-body max-w-[793px] mx-auto p-8"
            style={`
              -webkit-mask-image:
                radial-gradient(15px at 0 0, transparent 15px, black 15px),
                radial-gradient(15px at 100% 0, transparent 15px, black 15px),
                radial-gradient(15px at 0 100%, transparent 15px, black 15px),
                radial-gradient(15px at 100% 100%, transparent 15px, black 15px);
              mask-image:
                radial-gradient(15px at 0 0, transparent 15px, black 15px),
                radial-gradient(15px at 100% 0, transparent 15px, black 15px),
                radial-gradient(15px at 0 100%, transparent 15px, black 15px),
                radial-gradient(15px at 100% 100%, transparent 15px, black 15px);
              -webkit-mask-size: 100% 100%;
              mask-size: 100% 100%;
              -webkit-mask-repeat: no-repeat;
              mask-repeat: no-repeat;
              -webkit-mask-composite: source-in;
              mask-composite: intersect;
            `}
          >
            <h2
              class="text-balance text-center"
              set:html={markdownify(menu_section.title)}
            />
            <p
              class="text-text-dark text-center uppercase mb-4"
              set:html={markdownify(menu_section.subtitle)}
            />

            <ul class="mb-10 border border-primary p-4.5 relative z-20 bg-body">
              {menu_section.items.map((item, index) => (
                <>
                  <li class="flex justify-between items-center flex-wrap gap-3">
                    <div>
                      <h3 class="h5" set:html={markdownify(item.name)} />
                      <p
                        class="text-text-dark text-sm mb-2"
                        set:html={markdownify(item.description)}
                      />
                    </div>
                    <data
                      class="text-text-dark h5 font-secondary font-normal"
                      value={item.price}
                      set:html={markdownify(item.price)}
                    />
                  </li>
                  {index < menu_section.items.length - 1 && (
                    <div class="my-2 flex justify-center">
                      <SeparatorHalf
                        className={`h-5 w-fit ${
                          (index + 1) % 2 === 0 ? "-rotate-180" : ""
                        }`}
                        client:load
                      />
                    </div>
                  )}
                </>
              ))}
            </ul>

            <ImageMod
              src={"/images/cafe-juice/menu-decorative-1.png"}
              width={138}
              height={158}
              alt="Menu Badge"
              format="webp"
              class="absolute top-0 left-0"
            />
            <ImageMod
              src={"/images/cafe-juice/menu-decorative-2.png"}
              width={138}
              height={158}
              alt="Menu Badge"
              format="webp"
              class="absolute bottom-0 right-0"
            />
          </div>
        </div>
      </section>
    )
  }

  <CallToAction />
  <NewsletterSocial />
  <GallerySlider />
</Base>
