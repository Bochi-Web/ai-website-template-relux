---
import BlogCard from "@/components/BlogCard.astro";
import Pagination from "@/components/Pagination.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import PageHeader from "@/partials/PageHeader.astro";

const postIndex = await getListPage("blogListPage", "-index");
if (postIndex.data.draft) return Astro.redirect("/404");
const posts = await getSinglePage("blogSinglePage");
const sortedPosts = sortByDate(posts);
const totalPages: number = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);
---

<Base {...postIndex.data}>
  <PageHeader
    title={postIndex?.data.title}
    subtitle={postIndex?.data.subtitle}
    backgroundImage={postIndex?.data.image}
  />
  <section class="section bg-light">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-5 justify-center mb-14">
        {currentPosts.map((post) => <BlogCard data={post} />)}
      </div>
      <Pagination section={"blog"} currentPage={1} totalPages={totalPages} />
    </div>
  </section>
</Base>
