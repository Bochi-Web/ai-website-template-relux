---
import ImageMod from "@/components/ImageMod.astro";
import SeparatorHalf from "@/components/shapes/SeparatorHalf";
import DynamicIcon from "@/helpers/DynamicIcon";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import GallerySlider from "@/partials/GallerySlider.astro";
import ImageSlider from "@/partials/ImageSlider.astro";
import NewsletterSocial from "@/partials/NewsletterSocial.astro";
import PageHeader from "@/partials/PageHeader.astro";
import Testimonial from "@/partials/Testimonial.astro";

const pageIndex = await getListPage("about", "-index");
if (pageIndex.data.draft) return Astro.redirect("/404");

const { title, image, subtitle, about_section, service_section } =
  pageIndex.data;
---

<Base {...pageIndex.data}>
  <PageHeader title={title} subtitle={subtitle} backgroundImage={image} />

  {
    about_section.enable && (
      <section class="section bg-light">
        <div class="container">
          <SeparatorHalf
            className="-rotate-180 h-2.5 lg:h-6 w-fit"
            client:load
          />

          <div class="flex max-lg:flex-col gap-4 justify-between items-center my-10">
            <h2
              data-aos="fade-up-sm"
              data-aos-delay="150"
              class="flex-2/3 text-balance"
              set:html={markdownify(about_section.title)}
            />
            <p
              data-aos="fade-up-sm"
              data-aos-delay="150"
              class="h6 flex-1/3 text-text uppercase"
              set:html={markdownify(about_section.description)}
            />
          </div>

          <figure data-aos="zoom-in-sm" data-aos-delay="150">
            <ImageMod
              src={about_section.image}
              width={1688}
              height={900}
              alt={"Image of - " + about_section.title}
              format="webp"
              class="w-full h-auto object-cover border border-primary p-7"
            />
          </figure>
        </div>
      </section>
    )
  }

  {
    service_section.enable && (
      <section class="section pt-0 bg-light">
        <div class="container">
          <figure class="flex max-xl:flex-col max-xl:items-center gap-14 xl:gap-20">
            <ImageMod
              src={service_section.image}
              width={1688}
              height={900}
              alt={"Image of - " + service_section.title}
              format="webp"
              class="w-[90%] xl:w-[50%] h-auto object-cover border border-primary p-7"
            />
            <figcaption
              data-aos="fade-left-sm"
              data-aos-delay="200"
              class="w-[90%] xl:w-[50%]"
            >
              <h2
                class="text-balance mb-6"
                set:html={markdownify(service_section.title)}
              />
              <p
                class="h6 text-text mb-6"
                set:html={markdownify(service_section.operating_hours)}
              />

              <div class="grid sm:grid-cols-2 gap-5">
                {service_section.services.map((service) => (
                  <div class="border border-primary p-6">
                    <DynamicIcon
                      icon={service.icon}
                      width={48}
                      height={48}
                      className="w-12 h-12 object-contain text-primary mb-4"
                    />

                    <div>
                      <h3
                        class="h6 mb-1"
                        set:html={markdownify(service.label)}
                      />
                    </div>
                  </div>
                ))}
              </div>
            </figcaption>
          </figure>
        </div>
      </section>
    )
  }

  <Testimonial />
  <ImageSlider />
  <NewsletterSocial />
  <GallerySlider />
</Base>
